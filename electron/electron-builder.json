{
  "appId": "com.radiocoringao.admin",
  "productName": "Radio Coringao Admin",
  "executableName": "Radio Coringao Admin",
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.news",
    "icon": "build/icon.png"
  },
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "icon": "build/icon.ico",
    "executableName": "Radio Coringao Admin"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Radio Coringao Admin"
  },
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "dist-electron/main/**/*",
    "dist-electron/preload.js",
    "build/icon.png",
    "build/icon.ico"
  ],
  "extraResources": [],
  "compression": "normal"
}
