{
  "installCommand": "npm install --include=dev && npx prisma generate",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/admin/(.*)", "destination": "/api/admin" },
    { "source": "/api/cron/(.*)", "destination": "/api/cron/publish-scheduled" },
    { "source": "/api/test2", "destination": "/api/test2" },
    { "source": "/api/test", "destination": "/api/test" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
