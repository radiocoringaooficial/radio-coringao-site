{
  "version": 2,
  "installCommand": "npm install && npx prisma generate",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/admin.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/cron/publish-scheduled.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/test.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/test2.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/admin/(.*)",
      "dest": "api/admin.ts"
    },
    {
      "src": "/api/test2",
      "dest": "api/test2.ts"
    },
    {
      "src": "/api/test",
      "dest": "api/test.ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "* * * * *"
    }
  ]
}
